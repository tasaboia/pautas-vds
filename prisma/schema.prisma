generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusPauta {
  RECEBIDA
  EM_TRIAGEM
  AJUSTAR
  REVISADA
  SELECIONADA
  ENVIADA_TAMI
}

model Pauta {
  id                  Int         @id @default(autoincrement())
  tipoOracao          String
  pauta               String
  referencia          String
  idioma              String
  categoria           String?
  observacaoPublica   String?
  textoFinal          String?
  status              StatusPauta @default(RECEBIDA)
  revisada            Boolean     @default(false)
  enviadaParaTami     Boolean     @default(false)
  dia                 Int?
  ordemNoDia          Int?
  observacoesInternas String?
  criadoEm            DateTime    @default(now())
  atualizadoEm        DateTime    @updatedAt
}
